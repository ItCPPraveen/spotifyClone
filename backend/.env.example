# Database
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?appName=<appName>

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Google OAuth2 (if using Google login)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/callback

# Spotify API (optional — for Spotify search)
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=http://localhost:3001/auth/spotify/callback

# YouTube Data API v3
YOUTUBE_API_KEY=your_youtube_api_key

# JWT
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=24h

# Application
NODE_ENV=development
PORT=3001
LOG_LEVEL=debug
CACHE_TTL=86400

# CORS
CORS_ORIGIN=http://localhost:4200
